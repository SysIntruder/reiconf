! nsxiv
! Nsxiv.window.background: #000000
! Nsxiv.window.foreground: #FFFFFF

! nsxiv neovim theme
Nsxiv.window.background: #14161B
Nsxiv.window.foreground: #C4C6CD

! nsxiv dracula theme
! Nsxiv.window.background: #282A36
! Nsxiv.window.foreground: #F8F8F2

! nsxiv catppuccin theme
! Nsxiv.window.background: #1E1E2E
! Nsxiv.window.foreground: #CDD6F4

! dwm config
dwm.snap: 0
dwm.showbar: 1
dwm.topbar: 1
dwm.mfact: 0.55
dwm.nmaster: 1
dwm.resizehints: 0
dwm.lockfullscreen: 1
dwm.statusbar: dsblocks
dwm.centeredtitle: 1
dwm.borderpx: 0
! dwm.gappx: 12
! dwm.vertpad: 12
! dwm.sidepad: 12
! dwm.horizpadbar: 12
! dwm.vertpadbar: 12
dwm.gappx: 0
dwm.vertpad: 0
dwm.sidepad: 0
dwm.horizpadbar: 5
dwm.vertpadbar: 5
dwm.font: Terminus:pixelsize=16:antialias=false:autohint=false

! dwm suckless theme
! dwm.normbg: #222222
! dwm.normborder: #444444
! dwm.normfg: #BBBBBB
! dwm.selfg: #EEEEEE
! dwm.selbg: #005577
! dwm.urgbg: #CC3333

! dwm neovim theme
dwm.normbg: #14161B
dwm.normborder: #14161B
dwm.normfg: #C4C6CD
dwm.selfg: #E0E2EA
dwm.selbg: #2C2E33
dwm.urgbg: #590008

! dwm dracula theme
! dwm.normbg: #282A36
! dwm.normborder: #282A36
! dwm.normfg: #F8F8F2
! dwm.selfg: #F8F8F2
! dwm.selbg: #44475A
! dwm.urgbg: #FF5555

! dwm catppuccin theme
! dwm.normbg: #1E1E2E
! dwm.normborder: #1E1E2E
! dwm.normfg: #CDD6F4
! dwm.selfg: #CDD6F4
! dwm.selbg: #313244
! dwm.urgbg: #F38BA8

! dmenu config
dmenu.topbar: 1
! dmenu.vertpad: 12
! dmenu.sidepad: 12
! dmenu.user_bh: 12
dmenu.vertpad: 0
dmenu.sidepad: 0
dmenu.user_bh: 5
dmenu.font: Terminus:pixelsize=16:antialias=false:autohint=false

! dmenu suckless theme
! dmenu.normbg: #222222
! dmenu.normfg: #BBBBBB
! dmenu.selbg: #005577
! dmenu.selfg: #EEEEEE
! dmenu.outbg: #000000
! dmenu.outfg: #00FFFF

! dmenu neovim theme
dmenu.normbg: #14161B
dmenu.normfg: #C4C6CD
dmenu.selbg: #2C2E33
dmenu.selfg: #E0E2EA
dmenu.outbg: #07080d
dmenu.outfg: #007373

! dmenu dracula theme
! dmenu.normbg: #282A36
! dmenu.normfg: #F8F8F2
! dmenu.selbg: #44475A
! dmenu.selfg: #F8F8F2
! dmenu.outbg: #282A36
! dmenu.outfg: #f8f8f2

! dmenu catppuccin theme
! dmenu.normbg: #1E1E2E
