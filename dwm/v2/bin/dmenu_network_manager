#!/bin/sh

# dependencies
# - dmenu                (for dmenu) # require password patch
# - libnotify            (for notify-send)
# - ripgrep              (for rg)
# - coreutils            (for sort)
# - sed                  (for sed)
# - gawk                 (for awk)
# - networkmanager       (for nmcli)
# - nm-connection-editor (for nm-connection-editor)

RESCAN="Rescan WiFi"
NETMAN="Open Network Manager"
rescan="no"

get_wifi() {
 [ "$1" = "yes" ] && notify-send "Scanning WiFi" -t 10000

 nmcli -t -f IN-USE,SSID,SIGNAL dev wifi list --rescan "$1" |
   rg -v '::' |
   sort -t: -k1,1r -k3,3nr -k2,2 |
   sed -E 's/^\*:? *([^:]+):([0-9]+)/* \1 (\2%)/; s/^ ?:? *([^:]+):([0-9]+)/  \1 (\2%)/'
}

get_vpn() {
 nmcli -t -f ACTIVE,NAME,TYPE connection show |
   rg '.*:vpn' |
   sort -t: -k1,1r -k2,2 |
   awk -F: '{prefix=($1=="yes")?"*":" "; print prefix " " $2 ":" $3}'
}

menu() {
  {
    get_wifi "$1"
    printf "\n"
    get_vpn
    printf "\n%s\n%s" "$RESCAN" "$NETMAN"
  } | dmenu -i -l 25 -p "Networks"
}

handle() {
  if [ "$1" = "$RESCAN" ]; then
    rescan="yes"
    return 1

  elif [ "$1" = "$NETMAN" ]; then
    nm-connection-editor

  elif (echo "$1" | rg -q ':vpn$'); then
    vpn="$(echo "$1" | sed -E 's/^\*?\s*//; s/:(vpn)$//')"
    if (echo "$1" | rg -q '^\*'); then
      if nmcli connection down "$vpn"; then
        notify-send "$vpn successfully deactivated"

      else
        notify-send "failed to deactivating $vpn"
      fi

    else
      if nmcli connection up "$vpn"l; then
        notify-send "$vpn successfully activated" 

      else
        notify-send "failed on activating $vpn"
      fi
    fi

  elif [ -n "$1" ]; then
    ssid="$(echo "$1" | sed -En 's/^\*? *([^()]+[^[:space:]])[[:space:]]*\([0-9]+%\)/\1/p')"
    if (echo "$1" | rg -q '^\*'); then
      if nmcli connection down "$ssid"; then
        notify-send "$ssid successfully deactivated"

      else
        notify-send "failed to deactivating $ssid"

    else
      if nmcli device wifi connect "$ssid"; then
        notify-send "$ssid successfully activated"

      else
        pass=$(dmenu -P -p "Password for $ssid")
        if echo "$pass" | nmcli device wifi connect "$ssid" --ask; then
          notify-send "$ssid successfully activated"

        else
          notify-send "failed on activating $ssid"
        fi
      fi
    fi
  fi
  return 0
}

while true; do
  choice=$(menu "$rescan")
  rescan="no"
  handle "$choice" || continue
  break
done
