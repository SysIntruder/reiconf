#! /bin/sh

# based on dmenu-desktoponly patch and i3-dmenu-desktop
#
# dependencies
# - dmenu     (for dmenu, stest)
# - ripgrep   (for rg)
# - coreutils (for sort)
# - gtk3      (for gtk-launch)

dirs="${XDG_DATA_DIRS:-"$HOME/.local/share:/usr/local/share:/usr/share"}"
exclusion="mimeinfo\.cache|com\.zamaudio|geo.handler" # regex
inclusion="
org.pulseaudio.pavucontrol.desktop
"
IFS=:

for dir in $dirs; do
  [ -z "$dir" ] && continue
  dirs="${dirs}:${dir}/applications/*"
done
files=$(stest -f $dirs | rg -v $exclusion | sort -u)

apps=""
result=""
while IFS= read -r filename; do
  [ -z "$filename" ] && continue
  name=""
  terminal=""

  while IFS= read -r lines; do
    case "$lines" in
      Name=*)
        [ -z "$name" ] && name=${lines#Name=}
        ;;
      Terminal=*)
        terminal=${lines#Terminal=}
        ;;
    esac
  done < "$filename"

  # (##) match longest matching pattern (*/) and remove it
  # /usr/share/applications/htop.desktop > htop.desktop
  file="${filename##*/}"
  if [ -n "$name" ] &&
    (
      [ "$terminal" = false ] ||
      echo "$inclusion" | rg -F "$file"
    ); then
    apps="${apps}${name}:${file}
" # literally add newline
    result="${result}${name}
" # literally add newline
  fi
done << EOF
$files
EOF

# ($@) expand the args individually
selected=$(echo "$result" | dmenu -i "$@")
target=""
while IFS=: read -r key value; do
  if [ "$key" = "$selected" ]; then
    target="$value"
    break
  fi
done << EOF
$apps
EOF

[ -n "$target" ] && gtk-launch "$target"
